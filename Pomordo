<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Study With Me · Pomodoro</title>
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Lexend', sans-serif;
      min-height: 100vh;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }

    .bg {
      position: fixed;
      inset: 0;
      background-image: url('data:image/jpeg;base64,');
      background-size: cover;
      background-position: center;
      z-index: 0;
    }

    /* Subtle overlay for readability */
    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(30, 10, 0, 0.28);
      z-index: 1;
    }

    /* Logo */
    .logo {
      position: fixed;
      top: 28px;
      left: 36px;
      z-index: 10;
      animation: fadeIn 1.2s ease forwards;
    }
    .logo h1 {
      font-size: 1.35rem;
      font-weight: 300;
      color: white;
      text-shadow: 0 2px 20px rgba(0,0,0,0.5);
      letter-spacing: 0.02em;
      font-style: italic;
    }
    .logo span {
      display: block;
      font-size: 0.55rem;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.8);
      margin-top: 2px;
    }

    /* Main card */
    .card {
      position: relative;
      z-index: 10;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 36px;
      animation: fadeIn 1.4s ease forwards;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* Mode tabs */
    .tabs {
      display: flex;
      gap: 10px;
    }
    .tab {
      font-family: 'Lexend', sans-serif;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 8px 22px;
      border-radius: 999px;
      border: 2px solid rgba(255,255,255,0.65);
      background: transparent;
      color: rgba(255,255,255,0.85);
      cursor: pointer;
      transition: all 0.25s ease;
      letter-spacing: 0.02em;
    }
    .tab:hover {
      background: rgba(255,255,255,0.15);
      color: white;
      border-color: white;
    }
    .tab.active {
      background: white;
      color: #b85c00;
      border-color: white;
      font-weight: 600;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
    }

    /* Timer display */
    .timer {
      font-size: clamp(5.5rem, 16vw, 10rem);
      font-weight: 700;
      color: white;
      letter-spacing: -0.02em;
      line-height: 1;
      text-shadow:
        0 2px 40px rgba(0,0,0,0.5),
        0 0 80px rgba(255,180,80,0.2);
      user-select: none;
    }
    .timer.break { color: #fff3e0; }

    /* Sessions dots */
    .sessions {
      display: flex;
      gap: 8px;
      align-items: center;
    }
    .dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      background: rgba(255,255,255,0.3);
      border: 2px solid rgba(255,255,255,0.6);
      transition: background 0.3s;
    }
    .dot.done { background: white; }

    /* Controls */
    .controls {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .btn-start {
      font-family: 'Lexend', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      padding: 14px 52px;
      border-radius: 999px;
      background: white;
      color: #b85c00;
      border: none;
      cursor: pointer;
      letter-spacing: 0.05em;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
      transition: all 0.2s ease;
    }
    .btn-start:hover { transform: scale(1.05); box-shadow: 0 6px 30px rgba(0,0,0,0.4); }
    .btn-start:active { transform: scale(0.97); }

    .btn-icon {
      background: none;
      border: none;
      cursor: pointer;
      color: white;
      font-size: 1.4rem;
      opacity: 0.85;
      transition: all 0.2s;
      padding: 8px;
    }
    .btn-icon:hover { opacity: 1; transform: scale(1.15); }

    /* Settings modal */
    .modal-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.45);
      z-index: 100;
      align-items: center;
      justify-content: center;
      backdrop-filter: blur(6px);
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: rgba(255, 245, 230, 0.97);
      border-radius: 24px;
      padding: 36px 40px;
      min-width: 320px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.4);
      color: #5a2d00;
    }
    .modal h2 {
      font-size: 1.2rem;
      font-weight: 600;
      margin-bottom: 24px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .modal label {
      display: block;
      font-size: 0.8rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 6px;
      opacity: 0.7;
    }
    .modal input[type=number] {
      font-family: 'Lexend', sans-serif;
      width: 100%;
      padding: 10px 14px;
      border-radius: 10px;
      border: 2px solid rgba(184, 92, 0, 0.25);
      background: rgba(255,255,255,0.8);
      font-size: 1rem;
      font-weight: 500;
      color: #5a2d00;
      margin-bottom: 18px;
      outline: none;
      transition: border-color 0.2s;
    }
    .modal input[type=number]:focus { border-color: #ff7f50; }
    .modal-btns { display: flex; gap: 10px; margin-top: 8px; }
    .btn-save, .btn-cancel {
      font-family: 'Lexend', sans-serif;
      flex: 1;
      padding: 12px;
      border-radius: 12px;
      border: none;
      font-size: 0.9rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-save { background: #ff7f50; color: white; }
    .btn-save:hover { background: #ff6030; }
    .btn-cancel { background: rgba(0,0,0,0.08); color: #5a2d00; }
    .btn-cancel:hover { background: rgba(0,0,0,0.14); }

    /* Notification */
    .notif {
      position: fixed;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: white;
      color: #b85c00;
      padding: 14px 28px;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.95rem;
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      z-index: 200;
      transition: transform 0.4s cubic-bezier(0.34,1.56,0.64,1), opacity 0.4s;
      opacity: 0;
      pointer-events: none;
    }
    .notif.show { transform: translateX(-50%) translateY(0); opacity: 1; }
  </style>
</head>
<body>

<div class="bg" id="bg"></div>
<div class="overlay"></div>

<div class="logo">
  <h1>study with me</h1>
  <span>bypaloma.m</span>
</div>

<div class="card">
  <div class="tabs">
    <button class="tab active" data-mode="pomodoro">pomodoro</button>
    <button class="tab" data-mode="short">short break</button>
    <button class="tab" data-mode="long">long break</button>
  </div>

  <div class="timer" id="timer">25:00</div>

  <div class="sessions" id="sessions">
    <div class="dot"></div><div class="dot"></div><div class="dot"></div><div class="dot"></div>
  </div>

  <div class="controls">
    <button class="btn-icon" id="resetBtn" title="Reset">&#x21BA;</button>
    <button class="btn-start" id="startBtn">start</button>
    <button class="btn-icon" id="settingsBtn" title="Settings">⚙</button>
  </div>
</div>

<!-- Settings Modal -->
<div class="modal-overlay" id="modalOverlay">
  <div class="modal">
    <h2>⚙ Settings</h2>
    <label>Pomodoro (minutes)</label>
    <input type="number" id="setPomo" min="1" max="99" value="25"/>
    <label>Short Break (minutes)</label>
    <input type="number" id="setShort" min="1" max="99" value="5"/>
    <label>Long Break (minutes)</label>
    <input type="number" id="setLong" min="1" max="99" value="60"/>
    <div class="modal-btns">
      <button class="btn-cancel" id="cancelBtn">Cancel</button>
      <button class="btn-save" id="saveBtn">Save</button>
    </div>
  </div>
</div>

<div class="notif" id="notif"></div>

<script>
  // Inject background image
  document.getElementById('bg').style.backgroundImage = "url('data:image/jpeg;base64,')";

  // --- State ---
  let durations = { pomodoro: 25, short: 5, long: 60 };
  let mode = 'pomodoro';
  let totalSeconds = durations.pomodoro * 60;
  let remaining = totalSeconds;
  let running = false;
  let interval = null;
  let completedSessions = 0;

  const timerEl   = document.getElementById('timer');
  const startBtn  = document.getElementById('startBtn');
  const resetBtn  = document.getElementById('resetBtn');
  const settingsBtn = document.getElementById('settingsBtn');
  const sessionsEl = document.getElementById('sessions');
  const modalOverlay = document.getElementById('modalOverlay');
  const cancelBtn = document.getElementById('cancelBtn');
  const saveBtn   = document.getElementById('saveBtn');
  const notifEl   = document.getElementById('notif');

  function formatTime(s) {
    const m = Math.floor(s / 60);
    const sec = s % 60;
    return `${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
  }

  function render() {
    timerEl.textContent = formatTime(remaining);
    timerEl.className = 'timer' + (mode !== 'pomodoro' ? ' break' : '');
  }

  function setMode(m) {
    mode = m;
    totalSeconds = durations[m] * 60;
    remaining = totalSeconds;
    running = false;
    clearInterval(interval);
    startBtn.textContent = 'start';
    document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.mode === m));
    render();
  }

  function updateSessionDots() {
    const dots = sessionsEl.querySelectorAll('.dot');
    dots.forEach((d, i) => d.classList.toggle('done', i < completedSessions % 4));
  }

  function showNotif(msg) {
    notifEl.textContent = msg;
    notifEl.classList.add('show');
    setTimeout(() => notifEl.classList.remove('show'), 2800);
  }

  function tick() {
    if (remaining <= 0) {
      clearInterval(interval);
      running = false;
      startBtn.textContent = 'start';
      if (mode === 'pomodoro') {
        completedSessions++;
        updateSessionDots();
        showNotif('🌅 Session complete! Time for a break.');
      } else {
        showNotif('☀️ Break over! Ready to focus?');
      }
      return;
    }
    remaining--;
    render();
  }

  startBtn.addEventListener('click', () => {
    if (running) {
      clearInterval(interval);
      running = false;
      startBtn.textContent = 'start';
    } else {
      running = true;
      startBtn.textContent = 'pause';
      interval = setInterval(tick, 1000);
    }
  });

  resetBtn.addEventListener('click', () => {
    clearInterval(interval);
    running = false;
    startBtn.textContent = 'start';
    remaining = totalSeconds;
    render();
  });

  document.querySelectorAll('.tab').forEach(tab => {
    tab.addEventListener('click', () => setMode(tab.dataset.mode));
  });

  settingsBtn.addEventListener('click', () => {
    document.getElementById('setPomo').value = durations.pomodoro;
    document.getElementById('setShort').value = durations.short;
    document.getElementById('setLong').value = durations.long;
    modalOverlay.classList.add('open');
  });

  cancelBtn.addEventListener('click', () => modalOverlay.classList.remove('open'));
  modalOverlay.addEventListener('click', e => { if (e.target === modalOverlay) modalOverlay.classList.remove('open'); });

  saveBtn.addEventListener('click', () => {
    durations.pomodoro = parseInt(document.getElementById('setPomo').value) || 25;
    durations.short    = parseInt(document.getElementById('setShort').value) || 5;
    durations.long     = parseInt(document.getElementById('setLong').value) || 60;
    modalOverlay.classList.remove('open');
    setMode(mode);
    showNotif('✅ Settings saved!');
  });

  render();
  updateSessionDots();
</script>
</body>
</html>
